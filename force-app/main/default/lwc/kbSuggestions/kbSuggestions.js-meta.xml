<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Knowledge Suggestions</masterLabel>
    <description
  >AI-ranked knowledge base articles for case deflection. Subscribes to AIInsightsChannel for live updates on reclassification.</description>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>Case</object>
            </objects>
            <property
        name="topN"
        type="Integer"
        default="3"
        label="Number of suggestions"
        min="1"
        max="10"
      />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
